// test1.l26 — arithmetic, if/else, while, read/write
// Computes factorial of input n (n >= 0)
// Expected: factorial(5) = 120
{
    int n;
    int result;
    int i;

    read n;
    result = 1;
    i = 1;

    while (i <= n) {
        result = result * i;
        i = i + 1;
    }

    write result;

    // also test if/else
    if (result > 100) {
        write 1;
    } else {
        write 0;
    }
}
