// test4.l26 — bonus features: set equality and set comprehension
// Expected output:
//   1           (s1 == s2, same elements different order)
//   0           (s1 == s3, different sets)
//   {6, 8, 10}  (comprehension: { x*2 | x in s1 if x > 2 })
{
    set s1;
    set s2;
    set s3;
    set result;

    s1 = {1, 2, 3, 4, 5};
    s2 = {5, 4, 3, 2, 1};   // same elements as s1
    s3 = {1, 2, 3};

    // set equality (bonus)
    if (s1 == s2) {
        write 1;
    } else {
        write 0;
    }

    if (s1 == s3) {
        write 1;
    } else {
        write 0;
    }

    // set comprehension (bonus): { x*2 | x in s1 if x > 2 }
    // s1 = {1,2,3,4,5}, filter x>2 gives {3,4,5}, map x*2 gives {6,8,10}
    result = { x * 2 | x in s1 if x > 2 };
    write result;
}
