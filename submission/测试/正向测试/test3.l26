// test3.l26 — nested scopes and variable shadowing
// Matches the spec example exactly.
// Expected output:
//   {5, 6, 7}   (inner x as set)
//   {1, 2}      (inner s from outer scope)
//   10          (outer x restored after inner scope)
{
    int x;
    set s;
    x = 10;
    s = {1, 2};

    {
        set x;        // shadows outer int x
        x = {5, 6};
        add x 7;
        write x;      // {5, 6, 7}

        write s;      // finds outer s -> {1, 2}
    }

    write x;          // outer x = 10
}
